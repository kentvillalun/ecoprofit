// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Barangay {
  id           String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name         String
  code         String? @unique
  isRegistered Boolean @default(true)
  users        User[]
  sitios       Sitio[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Sitio {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name       String
  barangayId String   @db.Uuid
  barangay   Barangay @relation(fields: [barangayId], references: [id])
  users      User[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([barangayId, name])
  @@index([barangayId])
}

enum Role {
  RESIDENT
  BARANGAY_ADMIN
  SUPER_ADMIN
}

model User {
  id String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  
  barangayId String? @db.Uuid
  barangay Barangay? @relation(fields: [barangayId], references: [id])
  sitioId    String?   @db.Uuid
  sitio      Sitio?    @relation(fields: [sitioId], references: [id])

  role Role @default(RESIDENT)

  phoneNumber String @unique @db.VarChar(20)

  firstName String?
  lastName String?

  address String?
  purok String?

  passwordHash String 

  termsAccepted Boolean @default(false)
  termsAcceptedAt DateTime?

  isActive Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([barangayId])
  @@index([sitioId])
}
