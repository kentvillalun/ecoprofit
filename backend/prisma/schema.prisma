// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model BlackListedToken {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  token       String   @unique
  expiresAt   DateTime
  createdAt   DateTime @default(now())
}


model PasswordResetToken {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  phoneNumber String
  token       String   @unique
  expiresAt   DateTime
  createdAt   DateTime @default(now())

  @@index([phoneNumber])
}

model OtpVerification {
  id            String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  phoneNumber   String
  code          String

  expiresAt     DateTime
  createdAt     DateTime @default(now())

  @@index([phoneNumber])
}


model Barangay {
  id           String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name         String
  municipality String?
  province String?
  zipCode        String? @unique
  logoUrl String?
  redemptionMode RedemptionMode @default(POINTS)

  hasCollectionRequests Boolean @default(true)
  hasRedemptionManagement Boolean @default(false)
  hasRewardInventory Boolean @default(false)
  hasLeaderboard Boolean @default(false)

  isRegistered Boolean @default(true)
  users        User[]
  sitios       Sitio[]
  contactNumber String? @unique @db.VarChar(20)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  material Material[]
  program Program[]
}

enum RedemptionMode {
  POINTS
  CASH
  BOTH
}

model Sitio {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name       String
  barangayId String   @db.Uuid
  barangay   Barangay @relation(fields: [barangayId], references: [id])
  users      User[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([barangayId, name])
  @@index([barangayId])
}

enum Role {
  RESIDENT
  SUPER_ADMIN
  CAPTAIN
  SECRETARY
  TREASURER
  SK
  COLLECTOR
}

model User {
  id String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  
  barangayId String? @db.Uuid
  barangay Barangay? @relation(fields: [barangayId], references: [id])
  sitioId    String?   @db.Uuid
  sitio      Sitio?    @relation(fields: [sitioId], references: [id])

  role Role @default(RESIDENT)

  phoneNumber String @unique @db.VarChar(20)
  username String? @unique 

  firstName String?
  lastName String?

  address String?
  purok String?
  isVerified Boolean? @default(false)

  passwordHash String 

  termsAccepted Boolean @default(false)
  termsAcceptedAt DateTime?

  isActive Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  pickupRequest PickupRequests[]

  @@index([barangayId])
  @@index([sitioId])
}

model PickupRequests {
  id String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid

  userId String @db.Uuid
  user User @relation(fields: [userId], references: [id])
  
  materialId String? @db.Uuid
  material Material? @relation(fields: [materialId], references: [id])

  estimatedValue Float 
  estimatedUnit Unit @default(KG)
  status Status @default(REQUESTED)
  photoUrl String
  isScheduled Boolean @default(false)

  notes String?
  actualWeight Float?
  rewardEquivalent String?
  rejectionReason String?

  createdAt DateTime @default(now())
  approvedAt DateTime?
  collectedAt DateTime?
  rejectedAt DateTime?
  isAssorted Boolean @default(false)

  collectionItems CollectionItem[]
}

model Category {
  id String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name String @unique

  material Material[]
}

model Material {
  id String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name String
  categoryId String @db.Uuid

  category Category @relation(fields: [categoryId], references: [id])

  barangayId String @db.Uuid
  barangay Barangay @relation(fields: [barangayId], references: [id])

  defaultUnit Unit @default(KG)

  isActive Boolean @default(true)
  acceptNonSellable Boolean @default(false)

  pickupRequest PickupRequests[]
  collectionItem CollectionItem[]
  programMaterial ProgramMaterial[]
}

enum Unit {
  KG
  GRAMS
  LBS
  PIECE
}

enum Status {
  REQUESTED
  APPROVED
  IN_PROGRESS
  COLLECTED
  REJECTED
}

model CollectionItem {
  id String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid

  requestId String @db.Uuid
  request PickupRequests @relation(fields: [requestId], references: [id])

  materialId String @db.Uuid
  material Material @relation(fields: [materialId], references: [id])

  actualWeight Float
  actualUnit Unit

}

model Program {
  id String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid

  barangayId String @db.Uuid
  barangay Barangay @relation(fields: [barangayId], references: [id])

  name String
  allotedBudget Float
  maxPoints Float
  description String?
  isActive Boolean @default(true)
  isCashMode Boolean @default(false)
  createdAt DateTime @default(now()) 
  
  programMaterial ProgramMaterial[]
}

model ProgramMaterial {
  id String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  programId String @db.Uuid
  program Program @relation(fields: [programId], references: [id])

  materialId String @db.Uuid
  material Material @relation(fields: [materialId], references: [id])

  pointValue Float
  cashValue Float?
  createdAt DateTime @default(now())

  redemptionTransaction RedemptionTransaction[]

  @@unique([programId, materialId])
}

model RedemptionTransaction {
  id String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid

  programMaterialId String @db.Uuid
  programMaterial ProgramMaterial @relation(fields: [programMaterialId], references: [id])

  quantity Int
  collectorName String
  beneficiaryName String
  createdAt DateTime @default(now())
  currentValue Float
  educationalLevel EducationalLevel
}

enum EducationalLevel {
  PRIMARY
  SECONDARY
  TERTIARY
}

