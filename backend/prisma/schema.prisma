// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model BlackListedToken {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  token       String   @unique
  expiresAt   DateTime
  createdAt   DateTime @default(now())
}


model PasswordResetToken {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  phoneNumber String
  token       String   @unique
  expiresAt   DateTime
  createdAt   DateTime @default(now())

  @@index([phoneNumber])
}

model OtpVerification {
  id            String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  phoneNumber   String
  code          String

  expiresAt     DateTime
  createdAt     DateTime @default(now())

  @@index([phoneNumber])
}


model Barangay {
  id           String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name         String
  city         String?
  code         String? @unique
  isRegistered Boolean @default(true)
  users        User[]
  sitios       Sitio[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Sitio {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name       String
  barangayId String   @db.Uuid
  barangay   Barangay @relation(fields: [barangayId], references: [id])
  users      User[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([barangayId, name])
  @@index([barangayId])
}

enum Role {
  RESIDENT
  SUPER_ADMIN
  CAPTAIN
  SECRETARY
  TREASURER
  SK
  COLLECTOR
}

model User {
  id String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  
  barangayId String? @db.Uuid
  barangay Barangay? @relation(fields: [barangayId], references: [id])
  sitioId    String?   @db.Uuid
  sitio      Sitio?    @relation(fields: [sitioId], references: [id])

  role Role @default(RESIDENT)

  phoneNumber String @unique @db.VarChar(20)
  username String? @unique 

  firstName String?
  lastName String?

  address String?
  purok String?

  passwordHash String 

  termsAccepted Boolean @default(false)
  termsAcceptedAt DateTime?

  isActive Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  pickupRequest PickupRequests[]

  @@index([barangayId])
  @@index([sitioId])
}

model PickupRequests {
  id String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid

  userId String @db.Uuid

  user User @relation(fields: [userId], references: [id])
  materialType MaterialType @default(PLASTICS)
  estimatedWeight Float 
  weightUnit WeightUnit @default(KG)
  status Status @default(REQUESTED)
  photoUrl String
  isScheduled Boolean @default(false)

  notes String?
  actualWeight Float?
  rewardEquivalent String?
  rejectionReason String?

  createdAt DateTime @default(now())
  approvedAt DateTime?
  collectedAt DateTime?
  rejectedAt DateTime?

  collectionItems CollectionItem[]
}

enum MaterialType {
  METALS
  PAPERS
  BOTTLES
  PLASTICS
  ASSORTED
}

enum WeightUnit {
  KG
  GRAMS
  LBS
}

enum Status {
  REQUESTED
  APPROVED
  IN_PROGRESS
  COLLECTED
  REJECTED
}

model CollectionItem {
  id String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid

  requestId String @db.Uuid

  request PickupRequests @relation(fields: [requestId], references: [id])

  materialType MaterialType 
  actualWeight Float
  weightUnit WeightUnit


  
}

